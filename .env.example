# =============================================================================
# Umgebungs-Dateien (seit P2-M0):
#   .env.local       → DEV-Supabase-Projekt (Standard für dev-Server + Skripte)
#   .env.prod.local  → PRODUKTIV-Supabase-Projekt (Skripte nur mit TARGET=prod)
# Anleitung: docs/DEV-UMGEBUNG.md
# =============================================================================

# Supabase (Projekt-Einstellungen → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Nur Server (Seeds, Invites) – niemals im Client verwenden!
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Domain des Adminbereichs
ADMIN_DOMAIN=admin.projektplattform.ch

# Nur in .env.prod.local nötig (scripts/migrate-files-wattwil.ts):
# Basic-Auth des bestehenden Webservers, Format «benutzer:passwort»
LEGACY_BASIC_AUTH=
